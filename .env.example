OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_SYSTEM_PROMPT=Eres Dagerbot. Responde en espanol y se conciso.
PORT=3000
MAX_INPUT_CHARS=4096
HISTORY_LIMIT=10
SESSION_TTL_SECONDS=3600
RATE_LIMIT_IP_PER_MIN=60
RATE_LIMIT_SESSION_PER_MIN=100
# Optional (requires installing the 'redis' package)
# REDIS_URL=redis://localhost:6379

# Discord bot
# DISCORD_TOKEN=your_discord_bot_token
# DISCORD_PREFIX=!

# Required for slash command registration
# DISCORD_CLIENT_ID=your_bot_client_id

# Optional: commands register instantly to this guild (use for development only)
# Dev only: remove/comment in production.
# DISCORD_GUILD_ID=your_test_guild_id
