# ─── LLM Provider ───────────────────────────────────────────────────────────
# Which provider to use. Valid values: openai, anthropic, google (default: openai)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_key_here
OPENAI_MODEL=gpt-4.1-mini

# Anthropic
# ANTHROPIC_API_KEY=your_key_here
# ANTHROPIC_MODEL=claude-haiku-4-5

# Google Gemini
# GOOGLE_API_KEY=your_key_here
# GOOGLE_MODEL=gemini-2.0-flash

# Override the bot's system prompt (replaces the built-in MalO persona)
# LLM_SYSTEM_PROMPT=...

# ─── Bot ─────────────────────────────────────────────────────────────────────
BOT_TIMEZONE=America/Santiago

# ─── Discord ─────────────────────────────────────────────────────────────────
# DISCORD_TOKEN=your_discord_bot_token
# DISCORD_PREFIX=!

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
MAX_INPUT_CHARS=4096
HISTORY_LIMIT=10
SESSION_TTL_SECONDS=3600
RATE_LIMIT_IP_PER_MIN=60
RATE_LIMIT_SESSION_PER_MIN=100

# ─── Redis (optional) ────────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
